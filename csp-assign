<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Embedded Site Example</title>
    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
      }

      header {
        padding: 1rem;
        background: #111827;
        color: #f9fafb;
      }

      main {
        height: calc(100vh - 60px); /* adjust if you change header height */
      }

      iframe {
        width: 100%;
        height: 100%;
        border: none;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>Embedded Site Demo</h1>
    </header>

    <main>
      <!-- Replace example.com with your real URL -->
      <iframe
        src="https://invoicenow.co.ke"
        title="Embedded Site"
        loading="lazy"
        referrerpolicy="no-referrer"
      ></iframe>
    </main>
  </body>
</html>
